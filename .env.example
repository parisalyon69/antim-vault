# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use test keys (sk_test_...) in development, live keys (sk_live_...) in production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Server-side only — the price ID used for checkout session creation.
# Never use NEXT_PUBLIC_ prefix for this; it does not need to be in the browser bundle.
STRIPE_VAULT_PRICE_ID=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Rate limiting (Upstash Redis) ─────────────────────────────────────────────
# Optional — if absent, rate limiting is silently disabled (safe for local dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://vault.antim.services

# ── Letter encryption (server-only, never use NEXT_PUBLIC_ prefix) ────────────
# Generate with: openssl rand -base64 32
LETTER_ENCRYPTION_SECRET=

# ── Vercel Cron (server-only) ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Add this same value to Vercel Environment Variables.
# Vercel automatically sends it as Authorization: Bearer <CRON_SECRET> on cron requests.
CRON_SECRET=
